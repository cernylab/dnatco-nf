manifest {
    name        = 'dnatco-nf'
    description = 'Nucleic acid backbone conformer validation (NtC/DNATCO) and valence geometry (NA-VAL) analysis pipeline'
    author      = 'cernylab'
    version     = '1.0.0'
    nextflowVersion = '>=24.0'
}

params {
    // Coordinates input. '--input' and '--coords' are synonyms (--coords for dnatco.js).
    input      = null
    coords     = null

    // Output filename tag. Each output is named '<structure>_<outpref>_*', so the
    // '<structure>' base keeps names unique across a multi-file glob; outpref only
    // customizes the tag (default 'dnatco' preserves the historical names).
    outpref    = 'dnatco'
    dnatco_bin = "${projectDir}/bin"

    // Reflections input. Not supported by this pipeline (RSCC / density correlation
    // requires external programs); declared so reading it in main.nf doesn't warn.
    reflns     = null

    // Informational switches: print dnatco.js help/version and exit, ignoring
    // all other switches and inputs (--help takes precedence over --version).
    help       = false
    version    = false

    // Network control.
    //   --updateDnatco  Re-download the latest dnatco standalone into bin/, replacing the
    //                   local copy. Without it, an already-installed bin/ is reused; online
    //                   runs print a notice when a newer release tag is available.
    //   --offline       Disable ALL pipeline-initiated network operations: the GitHub release
    //                   check/download and the npm 'canvas' install for --report. Requires the
    //                   needed bits to be present already (bin/, a prepared .canvas cache for
    //                   --report, and the node:22 Docker image); otherwise those steps error or
    //                   are skipped. --updateDnatco is ignored when --offline is set.
    updateDnatco = false
    offline      = false

    // PDF report (--report) needs the native 'canvas' module; gated by ensureCanvas()
    // in main.nf. Declared so reading params.report doesn't warn; off by default.
    report     = false

    // dnatco.js outputs enabled by default. Any other dnatco.js switch can be
    // added on the command line (e.g. --ntcJson, --restraintsRmsd 0.4) and is
    // forwarded to dnatco.js verbatim by the DNATCO_CLASSIFY module.
    extendedCIF                = true
    anglesLengthsByResidueJson = true
}

docker {
    enabled = true
    // Run containers as the invoking user so outputs (and any bin/ writes) are owned by
    // the host user rather than root. $(id -u)/$(id -g) are evaluated in the task wrapper.
    runOptions = '--security-opt label=disable -u $(id -u):$(id -g)'
}

process {
    withName: 'DNATCO_CLASSIFY' {
        container = 'node:22'
    }
}
