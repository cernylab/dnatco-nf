manifest {
    name        = 'dnatco-nf'
    description = 'Nucleic acid backbone conformer validation (NtC/DNATCO) and valence geometry (NA-VAL) analysis pipeline'
    author      = 'cernylab'
    version     = '1.0.0'
    nextflowVersion = '>=24.0'
}

params {
    // Coordinates input. '--input' and '--coords' are synonyms (--coords for dnatco.js).
    input      = null
    coords     = null

    // Output filename tag. Each output is named '<structure>_<outpref>_*', so the
    // '<structure>' base keeps names unique across a multi-file glob; outpref only
    // customizes the tag (default 'dnatco' preserves the historical names).
    outpref    = 'dnatco'
    dnatco_bin = "${projectDir}/bin"

    // Container engine: 'docker' (default), 'podman' or 'container' (Apple container).
    // All are run by Nextflow natively (the matching scope is enabled below) and by the
    // manual engine calls in main.nf. 'container' needs Nextflow >= 26.04 on Apple silicon.
    containerEngine = 'docker'

    // Disabled dnatco.js switches: the pipeline either sets them itself (--prefix,
    // --outputDir) or doesn't support them (--reflns: RSCC / density correlation needs
    // external programs). Declared null so reading them in main.nf doesn't warn; a non-null
    // value means the user passed it and main.nf warns that it's ignored.
    reflns     = null
    prefix     = null
    outputDir  = null

    // Informational switches: print dnatco.js help/version and exit, ignoring
    // all other switches and inputs (--help takes precedence over --version).
    help       = false
    version    = false

    // Network control.
    //   --updateDnatco  Re-download the latest dnatco standalone into bin/, replacing the
    //                   local copy. Without it, an already-installed bin/ is reused; online
    //                   runs print a notice when a newer release tag is available.
    //   --offline       Disable ALL pipeline-initiated network operations: the GitHub release
    //                   check/download and the npm 'canvas' install for --report. Requires the
    //                   needed bits to be present already (bin/, a prepared .canvas cache for
    //                   --report, and the node:22 Docker image); otherwise those steps error or
    //                   are skipped. --updateDnatco is ignored when --offline is set.
    updateDnatco = false
    offline      = false

    // PDF report (--report) needs the native 'canvas' module; gated by ensureCanvas()
    // in main.nf. Declared so reading params.report doesn't warn; off by default.
    report     = false

    // dnatco.js outputs enabled by default. Any other dnatco.js switch can be
    // added on the command line (e.g. --ntcJson, --restraintsRmsd 0.4) and is
    // forwarded to dnatco.js verbatim by the DNATCO_CLASSIFY module.
    extendedCIF                = true
    anglesLengthsByResidueJson = true
}

// Container engine: enable whichever --containerEngine selects. Only the enabled scope's
// runOptions take effect. (Mirrored for our manual engine calls by hostEngineOpts() in main.nf.)
docker {
    enabled = params.containerEngine == 'docker'
    // On Linux: relabel bind mounts for SELinux and run as the invoking user so outputs
    // (and any bin/ writes) are owned by the host user, not root. $(id -u)/$(id -g) are
    // evaluated in the task wrapper. On macOS/Windows (Docker Desktop) both are dropped:
    // the SELinux option is meaningless there, and the file-sharing layer already maps
    // ownership back to the host user, so forcing the host uid tends to break HOME/npm.
    runOptions = System.getProperty('os.name')?.toLowerCase()?.contains('linux')
        ? '--security-opt label=disable -u $(id -u):$(id -g)'
        : ''
}

podman {
    enabled = params.containerEngine == 'podman'
    // Rootless podman maps container-root to the host user, so outputs are already owned by
    // the invoking user WITHOUT '-u' (forcing it would make them owned by an unusable subuid).
    // Keep only the SELinux relabel on Linux; nothing needed elsewhere.
    runOptions = System.getProperty('os.name')?.toLowerCase()?.contains('linux')
        ? '--security-opt label=disable'
        : ''
}

appleContainer {
    enabled = params.containerEngine == 'container'
    // Apple container (Nextflow >= 26.04, Apple silicon). node:22 is multi-arch, so the
    // arm64 image runs natively — no --rosetta / linux-amd64 platform override needed.
    // Each task runs in its own VM that maps ownership, so no SELinux/uid options.
}

process {
    withName: 'DNATCO_CLASSIFY' {
        container = 'node:22'
    }
}
